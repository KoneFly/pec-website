---
/**
 * 电路汇聚背景 · Circuit Flow (v2)
 * ---
 * 严格照抄 cpu代码.txt 的原始动画机制：
 *   - <circle cx="0" cy="0" r="X"> 保持不动
 *   - CSS 类 .flow-{n} 提供 @keyframes translate(x,y) 位移
 *   - mask 裁剪只显示路径描边处
 *
 * 主人反馈修复：
 *   ①背景遮字：整体 opacity 0.55 · 中心区加 radial mask 让文字区暗淡
 *   ②颜色太多：只保留浅蓝 + 白，芯片改纯丝印线（无 die 点阵、无多色文字）
 *   ③电流动画：CSS transform（不是 SMIL 也不是 RAF）
 *
 * viewBox 1000×1000，中央芯片 400-600
 */
---

<div class="circuit-bg" aria-hidden="true">
  <svg
    class="circuit-svg"
    viewBox="0 0 1000 1000"
    preserveAspectRatio="xMidYMid slice"
    xmlns="http://www.w3.org/2000/svg"
  >
    <defs>
      <!-- 光点渐变：只用一个浅蓝色 -->
      <radialGradient id="lp-grad" fx="0.5" fy="0.5">
        <stop offset="0%" stop-color="#FFFFFF" stop-opacity="1" />
        <stop offset="40%" stop-color="#BED6F8" stop-opacity="0.9" />
        <stop offset="100%" stop-color="#4288C9" stop-opacity="0" />
      </radialGradient>

      <!-- 中心 mask：文字区（芯片周围）淡化背景，避免遮字 -->
      <radialGradient id="fade-center" cx="0.5" cy="0.5" r="0.7">
        <!-- 中心 25% 半径内完全隐藏（给文字让位） -->
        <stop offset="0%" stop-color="black" />
        <stop offset="18%" stop-color="black" />
        <!-- 中心到 40% 之间渐变到显示 -->
        <stop offset="40%" stop-color="white" />
        <stop offset="100%" stop-color="white" />
      </radialGradient>
      <mask id="center-fade-mask">
        <rect width="1000" height="1000" fill="url(#fade-center)" />
      </mask>

      <!-- === 20 条 path 定义（M h v q 直角走线） === -->
      <path id="p-t1" d="M 200 -20 v 340 q 0 20 20 20 h 200" fill="none" />
      <path id="p-t2" d="M 400 -20 v 380 q 0 20 20 20 h 60" fill="none" />
      <path id="p-t3" d="M 600 -20 v 300 q 0 20 -20 20 h -80" fill="none" />
      <path id="p-t4" d="M 800 -20 v 320 q 0 20 -20 20 h -220" fill="none" />
      <path id="p-t5" d="M 500 -20 v 420" fill="none" />
      <path id="p-b1" d="M 180 1020 v -340 q 0 -20 20 -20 h 220" fill="none" />
      <path id="p-b2" d="M 420 1020 v -360 q 0 -20 20 -20 h 60" fill="none" />
      <path id="p-b3" d="M 580 1020 v -320 q 0 -20 -20 -20 h -40" fill="none" />
      <path id="p-b4" d="M 820 1020 v -340 q 0 -20 -20 -20 h -220" fill="none" />
      <path id="p-b5" d="M 500 1020 v -420" fill="none" />
      <path id="p-l1" d="M -20 200 h 340 q 20 0 20 20 v 200" fill="none" />
      <path id="p-l2" d="M -20 400 h 380 q 20 0 20 20 v 60" fill="none" />
      <path id="p-l3" d="M -20 600 h 300 q 20 0 20 -20 v -80" fill="none" />
      <path id="p-l4" d="M -20 800 h 320 q 20 0 20 -20 v -220" fill="none" />
      <path id="p-l5" d="M -20 500 h 420" fill="none" />
      <path id="p-r1" d="M 1020 180 h -340 q -20 0 -20 20 v 220" fill="none" />
      <path id="p-r2" d="M 1020 420 h -360 q -20 0 -20 20 v 60" fill="none" />
      <path id="p-r3" d="M 1020 580 h -320 q -20 0 20 -20 v -40" fill="none" />
      <path id="p-r4" d="M 1020 820 h -340 q -20 0 -20 -20 v -220" fill="none" />
      <path id="p-r5" d="M 1020 500 h -420" fill="none" />

      <!-- === mask 定义：每条 = 对应 path 的白色描边 === -->
      <mask id="m-t1"><use href="#p-t1" stroke="white" stroke-width="1.5" fill="none" /></mask>
      <mask id="m-t2"><use href="#p-t2" stroke="white" stroke-width="1.5" fill="none" /></mask>
      <mask id="m-t3"><use href="#p-t3" stroke="white" stroke-width="1.5" fill="none" /></mask>
      <mask id="m-t4"><use href="#p-t4" stroke="white" stroke-width="1.5" fill="none" /></mask>
      <mask id="m-t5"><use href="#p-t5" stroke="white" stroke-width="1.5" fill="none" /></mask>
      <mask id="m-b1"><use href="#p-b1" stroke="white" stroke-width="1.5" fill="none" /></mask>
      <mask id="m-b2"><use href="#p-b2" stroke="white" stroke-width="1.5" fill="none" /></mask>
      <mask id="m-b3"><use href="#p-b3" stroke="white" stroke-width="1.5" fill="none" /></mask>
      <mask id="m-b4"><use href="#p-b4" stroke="white" stroke-width="1.5" fill="none" /></mask>
      <mask id="m-b5"><use href="#p-b5" stroke="white" stroke-width="1.5" fill="none" /></mask>
      <mask id="m-l1"><use href="#p-l1" stroke="white" stroke-width="1.5" fill="none" /></mask>
      <mask id="m-l2"><use href="#p-l2" stroke="white" stroke-width="1.5" fill="none" /></mask>
      <mask id="m-l3"><use href="#p-l3" stroke="white" stroke-width="1.5" fill="none" /></mask>
      <mask id="m-l4"><use href="#p-l4" stroke="white" stroke-width="1.5" fill="none" /></mask>
      <mask id="m-l5"><use href="#p-l5" stroke="white" stroke-width="1.5" fill="none" /></mask>
      <mask id="m-r1"><use href="#p-r1" stroke="white" stroke-width="1.5" fill="none" /></mask>
      <mask id="m-r2"><use href="#p-r2" stroke="white" stroke-width="1.5" fill="none" /></mask>
      <mask id="m-r3"><use href="#p-r3" stroke="white" stroke-width="1.5" fill="none" /></mask>
      <mask id="m-r4"><use href="#p-r4" stroke="white" stroke-width="1.5" fill="none" /></mask>
      <mask id="m-r5"><use href="#p-r5" stroke="white" stroke-width="1.5" fill="none" /></mask>
    </defs>

    <!-- === 整体应用 center-fade-mask：芯片周围文字区显得透明 === -->
    <g mask="url(#center-fade-mask)">

      <!-- 图层 1：静态电路线（纯浅蓝细线，丝印感） -->
      <g stroke="#4288C9" stroke-width="0.6" stroke-opacity="0.30" fill="none" stroke-linecap="round">
        <use href="#p-t1" /><use href="#p-t2" /><use href="#p-t3" /><use href="#p-t4" /><use href="#p-t5" />
        <use href="#p-b1" /><use href="#p-b2" /><use href="#p-b3" /><use href="#p-b4" /><use href="#p-b5" />
        <use href="#p-l1" /><use href="#p-l2" /><use href="#p-l3" /><use href="#p-l4" /><use href="#p-l5" />
        <use href="#p-r1" /><use href="#p-r2" /><use href="#p-r3" /><use href="#p-r4" /><use href="#p-r5" />
      </g>

      <!-- 图层 2：光点 · SMIL animateMotion + mpath（SVG 原生动画，全浏览器支持） -->
      <!-- 每个光点顺 path 移动，mask 只显示路径描边处 -->
      <g mask="url(#m-t1)"><circle r="18" fill="url(#lp-grad)"><animateMotion dur="5s" repeatCount="indefinite" begin="0s"><mpath href="#p-t1"/></animateMotion></circle></g>
      <g mask="url(#m-t2)"><circle r="18" fill="url(#lp-grad)"><animateMotion dur="4.3s" repeatCount="indefinite" begin="-1.2s"><mpath href="#p-t2"/></animateMotion></circle></g>
      <g mask="url(#m-t3)"><circle r="18" fill="url(#lp-grad)"><animateMotion dur="5.8s" repeatCount="indefinite" begin="-0.6s"><mpath href="#p-t3"/></animateMotion></circle></g>
      <g mask="url(#m-t4)"><circle r="18" fill="url(#lp-grad)"><animateMotion dur="4.5s" repeatCount="indefinite" begin="-2.1s"><mpath href="#p-t4"/></animateMotion></circle></g>
      <g mask="url(#m-t5)"><circle r="18" fill="url(#lp-grad)"><animateMotion dur="4s" repeatCount="indefinite" begin="-1.5s"><mpath href="#p-t5"/></animateMotion></circle></g>
      <g mask="url(#m-b1)"><circle r="18" fill="url(#lp-grad)"><animateMotion dur="5.3s" repeatCount="indefinite" begin="-0.8s"><mpath href="#p-b1"/></animateMotion></circle></g>
      <g mask="url(#m-b2)"><circle r="18" fill="url(#lp-grad)"><animateMotion dur="4.1s" repeatCount="indefinite" begin="-2.4s"><mpath href="#p-b2"/></animateMotion></circle></g>
      <g mask="url(#m-b3)"><circle r="18" fill="url(#lp-grad)"><animateMotion dur="5.5s" repeatCount="indefinite" begin="-0.3s"><mpath href="#p-b3"/></animateMotion></circle></g>
      <g mask="url(#m-b4)"><circle r="18" fill="url(#lp-grad)"><animateMotion dur="4.7s" repeatCount="indefinite" begin="-1.8s"><mpath href="#p-b4"/></animateMotion></circle></g>
      <g mask="url(#m-b5)"><circle r="18" fill="url(#lp-grad)"><animateMotion dur="4.3s" repeatCount="indefinite" begin="-2.7s"><mpath href="#p-b5"/></animateMotion></circle></g>
      <g mask="url(#m-l1)"><circle r="18" fill="url(#lp-grad)"><animateMotion dur="5.1s" repeatCount="indefinite" begin="-0.5s"><mpath href="#p-l1"/></animateMotion></circle></g>
      <g mask="url(#m-l2)"><circle r="18" fill="url(#lp-grad)"><animateMotion dur="5.6s" repeatCount="indefinite" begin="-1.9s"><mpath href="#p-l2"/></animateMotion></circle></g>
      <g mask="url(#m-l3)"><circle r="18" fill="url(#lp-grad)"><animateMotion dur="4.2s" repeatCount="indefinite" begin="-0.2s"><mpath href="#p-l3"/></animateMotion></circle></g>
      <g mask="url(#m-l4)"><circle r="18" fill="url(#lp-grad)"><animateMotion dur="5.4s" repeatCount="indefinite" begin="-2.5s"><mpath href="#p-l4"/></animateMotion></circle></g>
      <g mask="url(#m-l5)"><circle r="18" fill="url(#lp-grad)"><animateMotion dur="4.6s" repeatCount="indefinite" begin="-1.1s"><mpath href="#p-l5"/></animateMotion></circle></g>
      <g mask="url(#m-r1)"><circle r="18" fill="url(#lp-grad)"><animateMotion dur="4.4s" repeatCount="indefinite" begin="-1.4s"><mpath href="#p-r1"/></animateMotion></circle></g>
      <g mask="url(#m-r2)"><circle r="18" fill="url(#lp-grad)"><animateMotion dur="5.2s" repeatCount="indefinite" begin="-0.7s"><mpath href="#p-r2"/></animateMotion></circle></g>
      <g mask="url(#m-r3)"><circle r="18" fill="url(#lp-grad)"><animateMotion dur="5.8s" repeatCount="indefinite" begin="-2.2s"><mpath href="#p-r3"/></animateMotion></circle></g>
      <g mask="url(#m-r4)"><circle r="18" fill="url(#lp-grad)"><animateMotion dur="4.3s" repeatCount="indefinite" begin="-1.6s"><mpath href="#p-r4"/></animateMotion></circle></g>
      <g mask="url(#m-r5)"><circle r="18" fill="url(#lp-grad)"><animateMotion dur="4.9s" repeatCount="indefinite" begin="-0.9s"><mpath href="#p-r5"/></animateMotion></circle></g>

      <!-- 图层 3：芯片丝印（纯浅蓝白线 · 无 die 点阵 · 无多色文字） -->
      <g class="chip">
        <!-- 4 边引脚（简化：每边 6 个，浅蓝色）-->
        <g fill="#4288C9" fill-opacity="0.55">
          <!-- 上边 -->
          <rect x="422" y="392" width="5" height="10" rx="1" />
          <rect x="446" y="392" width="5" height="10" rx="1" />
          <rect x="470" y="392" width="5" height="10" rx="1" />
          <rect x="525" y="392" width="5" height="10" rx="1" />
          <rect x="549" y="392" width="5" height="10" rx="1" />
          <rect x="573" y="392" width="5" height="10" rx="1" />
          <!-- 下边 -->
          <rect x="422" y="598" width="5" height="10" rx="1" />
          <rect x="446" y="598" width="5" height="10" rx="1" />
          <rect x="470" y="598" width="5" height="10" rx="1" />
          <rect x="525" y="598" width="5" height="10" rx="1" />
          <rect x="549" y="598" width="5" height="10" rx="1" />
          <rect x="573" y="598" width="5" height="10" rx="1" />
          <!-- 左边 -->
          <rect x="392" y="422" width="10" height="5" rx="1" />
          <rect x="392" y="446" width="10" height="5" rx="1" />
          <rect x="392" y="470" width="10" height="5" rx="1" />
          <rect x="392" y="525" width="10" height="5" rx="1" />
          <rect x="392" y="549" width="10" height="5" rx="1" />
          <rect x="392" y="573" width="10" height="5" rx="1" />
          <!-- 右边 -->
          <rect x="598" y="422" width="10" height="5" rx="1" />
          <rect x="598" y="446" width="10" height="5" rx="1" />
          <rect x="598" y="470" width="10" height="5" rx="1" />
          <rect x="598" y="525" width="10" height="5" rx="1" />
          <rect x="598" y="549" width="10" height="5" rx="1" />
          <rect x="598" y="573" width="10" height="5" rx="1" />
        </g>

        <!-- 芯片外框（透明填充 + 浅蓝描边，纯丝印线感） -->
        <rect x="400" y="400" width="200" height="200" rx="4"
              fill="none"
              stroke="#87A7F5"
              stroke-width="1.2"
              stroke-opacity="0.75" />

        <!-- 内框（更细，加深层次） -->
        <rect x="418" y="418" width="164" height="164" rx="2"
              fill="none"
              stroke="#4288C9"
              stroke-width="0.6"
              stroke-opacity="0.5" />

        <!-- Pin 1 标记（左上角小圆点） -->
        <circle cx="412" cy="412" r="2.5" fill="#87A7F5" fill-opacity="0.85" />

        <!-- 中央核心（单一浅蓝光点，无多色） -->
        <circle cx="500" cy="500" r="14"
                fill="#4288C9"
                fill-opacity="0.25"
                class="chip-halo" />
        <circle cx="500" cy="500" r="5"
                fill="#BED6F8"
                class="chip-core" />

        <!-- 丝印文字：单一浅蓝色，无渐变滚动 -->
        <text x="500" y="503"
              font-family="'JetBrains Mono', monospace"
              font-size="9"
              font-weight="600"
              fill="#BED6F8"
              fill-opacity="0.9"
              text-anchor="middle"
              letter-spacing="1.5">PEC</text>
        <text x="500" y="535"
              font-family="'JetBrains Mono', monospace"
              font-size="5"
              fill="#87A7F5"
              fill-opacity="0.55"
              text-anchor="middle"
              letter-spacing="2">MMXVI</text>
      </g>
    </g>
  </svg>
</div>

<style>
  .circuit-bg {
    position: fixed;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    overflow: hidden;
    /* 整体透明度降低，避免遮字 */
    opacity: 0.65;
    will-change: transform;
  }
  .circuit-svg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }

  /* ==============================================
     光点动画 · CSS transform（cpu代码.txt 同款机制）
     circle cx=0 cy=0 · translate 到路径关键点
     ============================================== */
  .lp {
    /* 起始位置由 translate 初始化 · 后续由 keyframes 驱动 */
    filter: blur(0.5px);
  }

  /* ===== 上方 5 条：从 (x, -20) 到 (x-final, 400)，中间经过弧线转向 ===== */
  @keyframes fl-t1 {
    0%   { transform: translate(200px, -20px); }
    70%  { transform: translate(200px, 320px); }
    75%  { transform: translate(220px, 340px); }
    100% { transform: translate(420px, 340px); }
  }
  .lp-t1 { animation: fl-t1 5s linear infinite; animation-delay: 0s; }

  @keyframes fl-t2 {
    0%   { transform: translate(400px, -20px); }
    85%  { transform: translate(400px, 360px); }
    90%  { transform: translate(420px, 380px); }
    100% { transform: translate(480px, 380px); }
  }
  .lp-t2 { animation: fl-t2 4.3s linear infinite; animation-delay: -1.2s; }

  @keyframes fl-t3 {
    0%   { transform: translate(600px, -20px); }
    70%  { transform: translate(600px, 280px); }
    75%  { transform: translate(580px, 300px); }
    100% { transform: translate(500px, 300px); }
  }
  .lp-t3 { animation: fl-t3 5.8s linear infinite; animation-delay: -0.6s; }

  @keyframes fl-t4 {
    0%   { transform: translate(800px, -20px); }
    60%  { transform: translate(800px, 300px); }
    65%  { transform: translate(780px, 320px); }
    100% { transform: translate(580px, 320px); }
  }
  .lp-t4 { animation: fl-t4 4.5s linear infinite; animation-delay: -2.1s; }

  @keyframes fl-t5 {
    0%   { transform: translate(500px, -20px); }
    100% { transform: translate(500px, 400px); }
  }
  .lp-t5 { animation: fl-t5 4s linear infinite; animation-delay: -1.5s; }

  /* ===== 下方 5 条：从 (x, 1020) 到 (x-final, 600) ===== */
  @keyframes fl-b1 {
    0%   { transform: translate(180px, 1020px); }
    70%  { transform: translate(180px, 680px); }
    75%  { transform: translate(200px, 660px); }
    100% { transform: translate(420px, 660px); }
  }
  .lp-b1 { animation: fl-b1 5.3s linear infinite; animation-delay: -0.8s; }

  @keyframes fl-b2 {
    0%   { transform: translate(420px, 1020px); }
    85%  { transform: translate(420px, 660px); }
    90%  { transform: translate(440px, 640px); }
    100% { transform: translate(480px, 640px); }
  }
  .lp-b2 { animation: fl-b2 4.1s linear infinite; animation-delay: -2.4s; }

  @keyframes fl-b3 {
    0%   { transform: translate(580px, 1020px); }
    85%  { transform: translate(580px, 700px); }
    90%  { transform: translate(560px, 680px); }
    100% { transform: translate(540px, 680px); }
  }
  .lp-b3 { animation: fl-b3 5.5s linear infinite; animation-delay: -0.3s; }

  @keyframes fl-b4 {
    0%   { transform: translate(820px, 1020px); }
    70%  { transform: translate(820px, 680px); }
    75%  { transform: translate(800px, 660px); }
    100% { transform: translate(580px, 660px); }
  }
  .lp-b4 { animation: fl-b4 4.7s linear infinite; animation-delay: -1.8s; }

  @keyframes fl-b5 {
    0%   { transform: translate(500px, 1020px); }
    100% { transform: translate(500px, 600px); }
  }
  .lp-b5 { animation: fl-b5 4.3s linear infinite; animation-delay: -2.7s; }

  /* ===== 左方 5 条：从 (-20, y) 到 (400, y-final) ===== */
  @keyframes fl-l1 {
    0%   { transform: translate(-20px, 200px); }
    70%  { transform: translate(320px, 200px); }
    75%  { transform: translate(340px, 220px); }
    100% { transform: translate(340px, 420px); }
  }
  .lp-l1 { animation: fl-l1 5.1s linear infinite; animation-delay: -0.5s; }

  @keyframes fl-l2 {
    0%   { transform: translate(-20px, 400px); }
    85%  { transform: translate(360px, 400px); }
    90%  { transform: translate(380px, 420px); }
    100% { transform: translate(380px, 480px); }
  }
  .lp-l2 { animation: fl-l2 5.6s linear infinite; animation-delay: -1.9s; }

  @keyframes fl-l3 {
    0%   { transform: translate(-20px, 600px); }
    70%  { transform: translate(280px, 600px); }
    75%  { transform: translate(300px, 580px); }
    100% { transform: translate(300px, 520px); }
  }
  .lp-l3 { animation: fl-l3 4.2s linear infinite; animation-delay: -0.2s; }

  @keyframes fl-l4 {
    0%   { transform: translate(-20px, 800px); }
    60%  { transform: translate(300px, 800px); }
    65%  { transform: translate(320px, 780px); }
    100% { transform: translate(320px, 580px); }
  }
  .lp-l4 { animation: fl-l4 5.4s linear infinite; animation-delay: -2.5s; }

  @keyframes fl-l5 {
    0%   { transform: translate(-20px, 500px); }
    100% { transform: translate(400px, 500px); }
  }
  .lp-l5 { animation: fl-l5 4.6s linear infinite; animation-delay: -1.1s; }

  /* ===== 右方 5 条：从 (1020, y) 到 (600, y-final) ===== */
  @keyframes fl-r1 {
    0%   { transform: translate(1020px, 180px); }
    70%  { transform: translate(680px, 180px); }
    75%  { transform: translate(660px, 200px); }
    100% { transform: translate(660px, 420px); }
  }
  .lp-r1 { animation: fl-r1 4.4s linear infinite; animation-delay: -1.4s; }

  @keyframes fl-r2 {
    0%   { transform: translate(1020px, 420px); }
    85%  { transform: translate(660px, 420px); }
    90%  { transform: translate(640px, 440px); }
    100% { transform: translate(640px, 480px); }
  }
  .lp-r2 { animation: fl-r2 5.2s linear infinite; animation-delay: -0.7s; }

  @keyframes fl-r3 {
    0%   { transform: translate(1020px, 580px); }
    85%  { transform: translate(700px, 580px); }
    90%  { transform: translate(680px, 560px); }
    100% { transform: translate(680px, 540px); }
  }
  .lp-r3 { animation: fl-r3 5.8s linear infinite; animation-delay: -2.2s; }

  @keyframes fl-r4 {
    0%   { transform: translate(1020px, 820px); }
    70%  { transform: translate(680px, 820px); }
    75%  { transform: translate(660px, 800px); }
    100% { transform: translate(660px, 580px); }
  }
  .lp-r4 { animation: fl-r4 4.3s linear infinite; animation-delay: -1.6s; }

  @keyframes fl-r5 {
    0%   { transform: translate(1020px, 500px); }
    100% { transform: translate(600px, 500px); }
  }
  .lp-r5 { animation: fl-r5 4.9s linear infinite; animation-delay: -0.9s; }

  /* 芯片核心呼吸 */
  .chip-core {
    animation: chip-pulse 2.5s ease-in-out infinite;
    transform-origin: 500px 500px;
    transform-box: view-box;
  }
  .chip-halo {
    animation: chip-halo 2.5s ease-in-out infinite;
    transform-origin: 500px 500px;
    transform-box: view-box;
  }
  @keyframes chip-pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.5; }
  }
  @keyframes chip-halo {
    0%, 100% { opacity: 0.25; }
    50% { opacity: 0.45; }
  }

  /* 尊重减动效偏好 */
  @media (prefers-reduced-motion: reduce) {
    .lp { display: none; }
    .chip-core, .chip-halo { animation: none; }
  }
</style>

<script>
  // 鼠标视差（轻量）
  const bg = document.querySelector<HTMLElement>('.circuit-bg');
  if (bg && !window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
    let tx = 0, ty = 0, cx = 0, cy = 0;
    let raf = 0;
    window.addEventListener('mousemove', (e) => {
      tx = (e.clientX / window.innerWidth - 0.5) * 8;
      ty = (e.clientY / window.innerHeight - 0.5) * 8;
    }, { passive: true });
    function loop() {
      cx += (tx - cx) * 0.05;
      cy += (ty - cy) * 0.05;
      bg.style.transform = `translate3d(${cx}px, ${cy}px, 0)`;
      raf = requestAnimationFrame(loop);
    }
    raf = requestAnimationFrame(loop);
    document.addEventListener('astro:before-swap', () => cancelAnimationFrame(raf), { once: true });
  }
</script>
