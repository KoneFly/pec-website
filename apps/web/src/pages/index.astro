---
import CircuitFlow from '../components/bg/CircuitFlow.astro';
import IntroScreen from '../components/bg/IntroScreen.astro';
/**
 * 变体 V4：Sui-IB 深蓝夜色氛围版
 * ---
 * DNA（从真实参考站扒来 · 不是浮浮酱瞎造）：
 *  - Sui-IB InternalBeyond 的 rgb(24,30,50) 深蓝夜色
 *  - Cormorant Garamond + Raleway + Noto Serif SC 高级衬线组合
 *  - Canvas 2D 分区小场景（不是超大 WebGL）: 星尘 + 光斑呼吸 + 月光环
 *  - Hero: LOADING 入场仪式 → 揭示 "光电科技 / PHOTOELECTRIC TECHNOLOGY"
 *  - Logo 处理: 中央徽章 + 光晕包围（月光徽章感）
 *  - 21st.dev Claude Azure 的 #4288c9 品牌蓝作为高光
 *
 * Trace: brand-spec §2.2 主色（Logo #0078D8 与 Claude Azure #4288c9 同色系）
 * 反 slop 检查: 无紫渐变 · 无 emoji · 无 GPU 粒子 · 无青紫霓虹撞衫
 */
---
<html lang="zh-CN" data-variant="v4-nightsky">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>V4 · 深蓝夜色氛围 - 光电科技</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@300;400;500;600;700&family=Raleway:wght@200;300;400;500;600&family=Noto+Serif+SC:wght@400;500;700&family=Noto+Sans+SC:wght@300;400;500&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
    <style>
      :root {
        --night-0: #0F1428;      /* 深蓝夜色 · 基底 */
        --night-1: #181E32;      /* Sui-IB 精确值 */
        --night-2: #232B4A;      /* 抬升层 */
        --night-3: #3A5587;      /* 蓝调抬色 */
        --moon-1: #A0BEEB;       /* 冰月蓝 */
        --moon-2: #BED6F8;       /* 冷白月光 */
        --brand: #4288C9;        /* Claude Azure 品牌蓝 */
        --brand-hi: #87A7F5;     /* 品牌高光 */
        --ink: #E6ECF5;          /* 主文字（月白色）*/
        --ink-soft: #A8B4C8;     /* 次文字 */
        --ink-mute: #6B7896;     /* 弱文字 */
        --line: rgba(160,190,235,0.10);
        --line-strong: rgba(160,190,235,0.22);
      }
      * { margin: 0; padding: 0; box-sizing: border-box; }
      html, body {
        font-family: 'Raleway', 'Noto Sans SC', system-ui, sans-serif;
        font-weight: 300;
        background: var(--night-0);
        color: var(--ink);
        -webkit-font-smoothing: antialiased;
        line-height: 1.6;
        overflow-x: hidden;
      }
      body::before {
        /* 全局背景纹理 · 星野感 */
        content: '';
        position: fixed; inset: 0;
        background:
          radial-gradient(ellipse 800px 400px at 20% 10%, rgba(66,136,201,0.12), transparent 50%),
          radial-gradient(ellipse 600px 500px at 80% 20%, rgba(135,167,245,0.08), transparent 50%),
          radial-gradient(ellipse 900px 300px at 50% 90%, rgba(66,136,201,0.06), transparent 50%);
        pointer-events: none;
        z-index: 0;
      }
      /* Canvas 分区星尘（Sui-IB 同款轻量画法）*/
      #stardust {
        position: fixed;
        inset: 0;
        pointer-events: none;
        z-index: 1;
        opacity: 0.7;
      }

      /* ==================== Loading 入场仪式 ==================== */
      #loader {
        position: fixed; inset: 0;
        background: var(--night-0);
        z-index: 100;
        display: flex; flex-direction: column;
        align-items: center; justify-content: center;
        gap: 2rem;
        transition: opacity 0.9s cubic-bezier(0.16, 1, 0.3, 1),
                    visibility 0.9s;
      }
      #loader.done { opacity: 0; visibility: hidden; }
      .loader-mark {
        font-family: 'Raleway', sans-serif;
        font-weight: 200;
        font-size: 0.7rem;
        letter-spacing: 0.5em;
        color: var(--ink-mute);
        text-transform: uppercase;
      }
      .loader-bar {
        width: 200px; height: 1px;
        background: var(--line-strong);
        position: relative;
        overflow: hidden;
      }
      .loader-fill {
        position: absolute; left: 0; top: 0; height: 100%;
        background: var(--brand);
        width: 0;
        box-shadow: 0 0 12px var(--brand);
        transition: width 0.1s linear;
      }
      .loader-percent {
        font-family: 'JetBrains Mono', monospace;
        font-size: 0.75rem;
        color: var(--ink-soft);
        letter-spacing: 0.15em;
      }

      /* ==================== 顶部导航 ==================== */
      header {
        position: fixed; top: 0; left: 0; right: 0; z-index: 50;
        background: rgba(15,20,40,0.6);
        backdrop-filter: blur(20px);
        border-bottom: 1px solid var(--line);
        opacity: 0; transform: translateY(-100%);
        transition: opacity 1s cubic-bezier(0.16, 1, 0.3, 1) 0.4s,
                    transform 1s cubic-bezier(0.16, 1, 0.3, 1) 0.4s;
      }
      body.ready header { opacity: 1; transform: translateY(0); }
      nav {
        max-width: 1280px; margin: 0 auto;
        padding: 1.25rem 2rem;
        display: flex; align-items: center; justify-content: space-between;
      }
      .brand-block {
        display: flex; align-items: center; gap: 0.75rem;
        text-decoration: none; color: var(--ink);
      }
      .brand-block img {
        width: 56px; height: 56px; border-radius: 50%;
        border: 1px solid var(--line-strong);
        box-shadow: 0 0 24px rgba(66,136,201,0.4);
      }
      .brand-cn {
        font-family: 'Noto Serif SC', serif;
        font-weight: 500; font-size: 1.2rem;
        letter-spacing: 0.05em;
      }
      .brand-en {
        font-family: 'Raleway', sans-serif;
        font-weight: 300; font-size: 0.65rem;
        color: var(--ink-mute);
        letter-spacing: 0.2em;
        text-transform: uppercase;
        margin-top: 2px;
      }
      nav ul {
        display: flex; gap: 0.5rem; list-style: none; align-items: center;
      }
      nav a {
        text-decoration: none; color: var(--ink-soft);
        font-family: 'Raleway', sans-serif;
        font-weight: 300; font-size: 0.85rem;
        padding: 0.5rem 1rem; letter-spacing: 0.1em;
        text-transform: uppercase;
        transition: color 0.2s;
        position: relative;
      }
      nav a::after {
        content: ''; position: absolute;
        left: 1rem; right: 1rem; bottom: 0.35rem;
        height: 1px; background: var(--brand);
        transform: scaleX(0); transform-origin: left;
        transition: transform 0.3s ease;
      }
      nav a:hover { color: var(--ink); }
      nav a:hover::after { transform: scaleX(1); }
      .nav-cta {
        color: var(--night-0) !important;
        background: var(--brand);
        border-radius: 999px;
        letter-spacing: 0.1em;
      }
      .nav-cta::after { display: none; }
      .nav-cta:hover {
        background: var(--brand-hi);
        color: var(--night-0) !important;
      }

      /* ==================== Hero · 深蓝夜色 + 电流汇聚背景 ==================== */
      .hero {
        position: relative;
        z-index: 2;
        min-height: 100vh;
        display: flex; flex-direction: column;
        align-items: center; justify-content: center;
        padding: 6rem 2rem 4rem;
        text-align: center;
        overflow: hidden;  /* 让背景 SVG 不溢出 */
      }
      /* Hero 内所有直接子元素浮在 fixed 电路背景之上 */
      .hero > * {
        position: relative;
        z-index: 3;
      }
      /* .circuit-bg 现在是 fixed（在 CircuitFlow.astro 里），
         不再是 hero 的子元素定位上下文，通过 z-index 分层 */
      /* 月光徽章 Logo · 已被 ConvergenceFlow 内嵌的 CenterEmblem 取代 · 保留样式以防回退 */
      .logo-badge {
        display: none;
        position: relative;
        margin-bottom: 3rem;
        opacity: 0; transform: scale(0.8);
        transition: opacity 1.4s cubic-bezier(0.16, 1, 0.3, 1) 0.2s,
                    transform 1.4s cubic-bezier(0.16, 1, 0.3, 1) 0.2s;
      }
      body.ready .logo-badge { opacity: 1; transform: scale(1); }
      .logo-badge img {
        width: 110px; height: 110px; border-radius: 50%;
        position: relative; z-index: 2;
        border: 1px solid var(--line-strong);
        box-shadow: 0 0 60px rgba(66,136,201,0.4);
      }
      .logo-badge::before,
      .logo-badge::after {
        content: '';
        position: absolute; inset: -20px;
        border: 1px solid var(--brand);
        border-radius: 50%;
        opacity: 0.3;
        animation: pulse-ring 4s ease-out infinite;
      }
      .logo-badge::after {
        animation-delay: 2s;
      }
      @keyframes pulse-ring {
        0% { transform: scale(1); opacity: 0.5; }
        100% { transform: scale(1.6); opacity: 0; }
      }

      /* Hero 副标 */
      .hero-eyebrow {
        font-family: 'JetBrains Mono', monospace;
        font-size: 0.7rem;
        letter-spacing: 0.4em;
        color: var(--brand-hi);
        text-transform: uppercase;
        margin-bottom: 1.5rem;
        opacity: 0;
        transform: translateY(20px);
        transition: opacity 1s ease 0.5s, transform 1s cubic-bezier(0.16, 1, 0.3, 1) 0.5s;
      }
      body.ready .hero-eyebrow { opacity: 1; transform: translateY(0); }

      /* Hero 大字 - 中英双行 */
      .hero-cn {
        font-family: 'Noto Serif SC', 'Cormorant Garamond', serif;
        font-weight: 500;
        font-size: clamp(3rem, 8vw, 6rem);
        line-height: 1.05;
        letter-spacing: -0.02em;
        margin-bottom: 0.5rem;
        opacity: 0;
        transform: translateY(30px);
        transition: opacity 1.2s ease 0.7s, transform 1.2s cubic-bezier(0.16, 1, 0.3, 1) 0.7s;
      }
      body.ready .hero-cn { opacity: 1; transform: translateY(0); }
      .hero-cn em {
        font-style: normal;
        color: var(--brand-hi);
        text-shadow: 0 0 32px rgba(135,167,245,0.5);
      }

      .hero-en {
        font-family: 'Cormorant Garamond', serif;
        font-weight: 300;
        font-style: italic;
        font-size: clamp(1.25rem, 3vw, 2rem);
        color: var(--moon-1);
        letter-spacing: 0.05em;
        margin-bottom: 3rem;
        opacity: 0;
        transform: translateY(30px);
        transition: opacity 1.2s ease 0.9s, transform 1.2s cubic-bezier(0.16, 1, 0.3, 1) 0.9s;
      }
      body.ready .hero-en { opacity: 1; transform: translateY(0); }

      /* Hero motto - 协会信条 */
      .hero-motto {
        font-family: 'Noto Serif SC', serif;
        font-weight: 400;
        font-size: 1.1rem;
        color: var(--ink-soft);
        letter-spacing: 0.15em;
        max-width: 600px;
        line-height: 2;
        margin-bottom: 3rem;
        opacity: 0;
        transition: opacity 1.5s ease 1.1s;
      }
      body.ready .hero-motto { opacity: 1; }
      .hero-motto em {
        font-style: normal;
        color: var(--brand-hi);
      }

      /* CTA */
      .hero-cta {
        display: flex; gap: 1.5rem; flex-wrap: wrap; justify-content: center;
        opacity: 0;
        transform: translateY(20px);
        transition: opacity 1s ease 1.3s, transform 1s cubic-bezier(0.16, 1, 0.3, 1) 1.3s;
      }
      body.ready .hero-cta { opacity: 1; transform: translateY(0); }
      .btn {
        padding: 0.9rem 2rem;
        border-radius: 999px;
        font-family: 'Raleway', sans-serif;
        font-weight: 400;
        font-size: 0.9rem;
        letter-spacing: 0.2em;
        text-transform: uppercase;
        text-decoration: none;
        transition: all 0.25s;
      }
      .btn-primary {
        background: var(--brand);
        color: var(--night-0);
        box-shadow: 0 0 30px rgba(66,136,201,0.4);
      }
      .btn-primary:hover {
        background: var(--brand-hi);
        transform: translateY(-2px);
        box-shadow: 0 0 40px rgba(135,167,245,0.6);
      }
      .btn-ghost {
        background: transparent;
        color: var(--ink);
        border: 1px solid var(--line-strong);
      }
      .btn-ghost:hover {
        border-color: var(--brand);
        color: var(--brand-hi);
      }

      /* Scroll cue */
      .scroll-cue {
        position: absolute;
        bottom: 2rem; left: 50%;
        transform: translateX(-50%);
        font-family: 'JetBrains Mono', monospace;
        font-size: 0.65rem;
        letter-spacing: 0.3em;
        color: var(--ink-mute);
        text-transform: uppercase;
        opacity: 0;
        transition: opacity 1s ease 1.6s;
      }
      body.ready .scroll-cue { opacity: 0.7; }
      .scroll-cue::after {
        content: '';
        display: block;
        width: 1px; height: 24px;
        background: linear-gradient(to bottom, var(--brand), transparent);
        margin: 0.5rem auto 0;
        animation: cue-slide 2s ease-in-out infinite;
      }
      @keyframes cue-slide {
        0%, 100% { transform: translateY(0); opacity: 1; }
        50% { transform: translateY(8px); opacity: 0.3; }
      }

      /* ==================== 数据展示区 ==================== */
      .stats {
        position: relative; z-index: 2;
        max-width: 1280px; margin: 0 auto;
        padding: 6rem 2rem;
        border-top: 1px solid var(--line);
        border-bottom: 1px solid var(--line);
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 0;
      }
      .stat-cell {
        padding: 0 2rem;
        border-left: 1px solid var(--line);
        text-align: center;
      }
      .stat-cell:first-child { border-left: none; }
      .stat-num {
        font-family: 'Cormorant Garamond', serif;
        font-weight: 500;
        font-size: 4rem;
        line-height: 1;
        color: var(--brand-hi);
        margin-bottom: 0.75rem;
        text-shadow: 0 0 40px rgba(135,167,245,0.3);
      }
      .stat-num sup {
        font-size: 1.5rem;
        vertical-align: super;
        color: var(--brand);
        margin-left: 0.15rem;
      }
      .stat-label {
        font-family: 'Raleway', sans-serif;
        font-weight: 300;
        font-size: 0.75rem;
        letter-spacing: 0.25em;
        color: var(--ink-mute);
        text-transform: uppercase;
      }
      .stat-label-cn {
        font-family: 'Noto Sans SC', sans-serif;
        font-size: 0.85rem;
        color: var(--ink-soft);
        margin-top: 0.35rem;
      }

      /* ==================== 精神四联卡 ==================== */
      .manifesto {
        position: relative; z-index: 2;
        padding: 8rem 2rem;
      }
      .section-inner {
        max-width: 1280px; margin: 0 auto;
      }
      .section-tag {
        font-family: 'JetBrains Mono', monospace;
        font-size: 0.7rem;
        letter-spacing: 0.4em;
        color: var(--brand-hi);
        text-transform: uppercase;
        margin-bottom: 1.5rem;
      }
      .section-title {
        font-family: 'Cormorant Garamond', 'Noto Serif SC', serif;
        font-weight: 400;
        font-size: clamp(2.5rem, 5vw, 4rem);
        line-height: 1.15;
        letter-spacing: -0.02em;
        margin-bottom: 4rem;
        max-width: 800px;
      }
      .section-title em {
        font-style: italic;
        color: var(--brand-hi);
      }

      .manifesto-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 1.5rem;
      }
      .manifesto-card {
        padding: 2.5rem 2rem;
        background: linear-gradient(180deg, rgba(35,43,74,0.5) 0%, rgba(24,30,50,0.5) 100%);
        border: 1px solid var(--line);
        border-radius: 4px;
        position: relative;
        overflow: hidden;
        transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
      }
      .manifesto-card::before {
        content: '';
        position: absolute; top: 0; left: 0; right: 0; height: 1px;
        background: linear-gradient(90deg, transparent, var(--brand), transparent);
        opacity: 0.5;
      }
      .manifesto-card:hover {
        transform: translateY(-6px);
        border-color: var(--brand);
        background: linear-gradient(180deg, rgba(58,85,135,0.35) 0%, rgba(24,30,50,0.6) 100%);
      }
      .card-num {
        font-family: 'JetBrains Mono', monospace;
        font-size: 0.7rem;
        letter-spacing: 0.2em;
        color: var(--brand-hi);
        margin-bottom: 1.5rem;
      }
      .card-cn {
        font-family: 'Noto Serif SC', serif;
        font-weight: 500;
        font-size: 2rem;
        margin-bottom: 0.5rem;
      }
      .card-en {
        font-family: 'Cormorant Garamond', serif;
        font-style: italic;
        font-size: 0.95rem;
        color: var(--moon-1);
        letter-spacing: 0.05em;
        margin-bottom: 1.5rem;
      }
      .card-desc {
        font-family: 'Noto Sans SC', sans-serif;
        font-size: 0.85rem;
        color: var(--ink-soft);
        line-height: 1.85;
      }

      /* ==================== 研究方向 · 长卡 ==================== */
      .fields {
        position: relative; z-index: 2;
        padding: 6rem 2rem;
        background:
          linear-gradient(180deg, transparent, rgba(35,43,74,0.3) 20%, rgba(35,43,74,0.3) 80%, transparent),
          var(--night-0);
      }
      .field-list {
        display: flex; flex-direction: column; gap: 0;
      }
      .field-row {
        display: grid;
        grid-template-columns: 100px 1fr auto;
        gap: 3rem;
        padding: 2.5rem 1rem;
        align-items: baseline;
        border-top: 1px solid var(--line);
        transition: all 0.3s;
      }
      .field-row:last-child { border-bottom: 1px solid var(--line); }
      .field-row:hover {
        background: linear-gradient(90deg, rgba(66,136,201,0.08), transparent);
        padding-left: 2rem;
      }
      .field-num {
        font-family: 'Cormorant Garamond', serif;
        font-size: 3rem;
        font-weight: 300;
        color: var(--brand);
        line-height: 1;
      }
      .field-content h3 {
        font-family: 'Noto Serif SC', serif;
        font-weight: 500;
        font-size: 1.75rem;
        margin-bottom: 0.5rem;
        color: var(--ink);
      }
      .field-content .field-en {
        font-family: 'Cormorant Garamond', serif;
        font-style: italic;
        font-size: 1rem;
        color: var(--moon-1);
        margin-bottom: 1rem;
        letter-spacing: 0.05em;
      }
      .field-content p {
        font-size: 0.95rem;
        color: var(--ink-soft);
        line-height: 1.8;
        max-width: 60ch;
      }
      .field-tags {
        display: flex; gap: 0.5rem;
        flex-wrap: wrap;
        justify-content: flex-end;
      }
      .field-tag {
        font-family: 'JetBrains Mono', monospace;
        font-size: 0.7rem;
        letter-spacing: 0.1em;
        padding: 0.35rem 0.75rem;
        background: rgba(66,136,201,0.1);
        border: 1px solid var(--line-strong);
        color: var(--moon-1);
        border-radius: 999px;
      }

      /* ==================== 大字 CTA ==================== */
      .final-cta {
        position: relative; z-index: 2;
        padding: 10rem 2rem;
        text-align: center;
      }
      .final-cta-title {
        font-family: 'Cormorant Garamond', 'Noto Serif SC', serif;
        font-weight: 400;
        font-size: clamp(3rem, 7vw, 5.5rem);
        line-height: 1.15;
        letter-spacing: -0.02em;
        margin-bottom: 3rem;
      }
      .final-cta-title em {
        font-style: italic;
        color: var(--brand-hi);
        text-shadow: 0 0 40px rgba(135,167,245,0.4);
      }
      .final-cta-sub {
        font-family: 'Noto Sans SC', sans-serif;
        color: var(--ink-soft);
        max-width: 600px;
        margin: 0 auto 3rem;
        line-height: 1.85;
      }

      /* ==================== Footer ==================== */
      footer {
        position: relative; z-index: 2;
        padding: 5rem 2rem 2rem;
        border-top: 1px solid var(--line);
      }
      .footer-grid {
        max-width: 1280px; margin: 0 auto;
        display: grid;
        grid-template-columns: 2fr 1fr 1fr 1fr;
        gap: 3rem;
      }
      footer h4 {
        font-family: 'Raleway', sans-serif;
        font-weight: 400;
        font-size: 0.7rem;
        letter-spacing: 0.25em;
        color: var(--brand-hi);
        text-transform: uppercase;
        margin-bottom: 1.25rem;
        padding-bottom: 0.75rem;
        border-bottom: 1px solid var(--line);
      }
      footer p, footer li {
        font-size: 0.85rem;
        color: var(--ink-soft);
        line-height: 1.85;
      }
      footer ul { list-style: none; }
      footer a {
        color: inherit;
        text-decoration: none;
        transition: color 0.2s;
      }
      footer a:hover { color: var(--brand-hi); }
      .colophon {
        max-width: 1280px; margin: 3rem auto 0;
        padding: 2rem 0 0;
        border-top: 1px solid var(--line);
        display: flex; justify-content: space-between;
        flex-wrap: wrap; gap: 1rem;
        font-family: 'JetBrains Mono', monospace;
        font-size: 0.7rem;
        letter-spacing: 0.05em;
        color: var(--ink-mute);
      }

      /* ==================== 响应式 ==================== */
      @media (max-width: 900px) {
        .stats { grid-template-columns: repeat(2, 1fr); gap: 3rem 0; }
        .stat-cell:nth-child(3) { border-left: none; padding-top: 3rem; border-top: 1px solid var(--line); }
        .stat-cell:nth-child(4) { padding-top: 3rem; border-top: 1px solid var(--line); }
        .manifesto-grid { grid-template-columns: repeat(2, 1fr); }
        .field-row { grid-template-columns: auto 1fr; }
        .field-tags { grid-column: 1 / -1; justify-content: flex-start; }
