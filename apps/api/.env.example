# ===== 服务配置 =====
PORT=3000
NODE_ENV=development

# ===== 数据库 =====
DATABASE_URL=file:./data/pec.db

# ===== CORS（前端域名，多个逗号分隔） =====
CORS_ORIGIN=http://localhost:4321,https://your-org.github.io

# ===== 主人后台 =====
# 生成密码哈希：node -e "console.log(require('bcryptjs').hashSync('your_password', 12))"
ADMIN_PASSWORD_HASH=
# JWT 密钥，建议 32+ 字符随机串：node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=

# ===== 拓竹打印机（在打印机屏幕开 LAN Mode 后取） =====
BAMBU_A1_IP=
BAMBU_A1_ACCESS_CODE=
BAMBU_A1_SERIAL=

BAMBU_X2D_IP=
BAMBU_X2D_ACCESS_CODE=
BAMBU_X2D_SERIAL=
