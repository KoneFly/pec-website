{
  "name": "pec-website",
  "version": "0.1.0",
  "private": true,
  "description": "Photonics & Electronics Club Official Website",
  "scripts": {
    "dev:web": "pnpm --filter @pec/web dev",
    "dev:api": "pnpm --filter @pec/api dev",
    "build": "pnpm -r build",
    "build:web": "pnpm --filter @pec/web build",
    "build:api": "pnpm --filter @pec/api build",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "typescript": "^5.7.2"
  },
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=9.0.0"
  }
}
